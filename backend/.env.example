# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MySQL ─────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=campuscore

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=24h

# ── Admin credentials (used on first-run seed) ────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
